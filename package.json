{
  "name": "mode7",
  "lovefile": "mode7",
  "version": "1.0.0",
  "private": true,
  "description": "Mode 7 rendering experiment built with Lua and LOVE2D",
  "scripts": {
    "setup": "npm install && node src/love2d4me/scripts/setup-love.js && node src/love2d4me/scripts/install-hooks.js",
    "lint": "node src/love2d4me/scripts/lint-vars.js src",
    "start": "node src/love2d4me/scripts/start.js",
    "dev": "node src/love2d4me/scripts/dev.js",
    "pack": "node src/love2d4me/scripts/pack-love.js",
    "build": "node src/love2d4me/scripts/build-web.js",
    "build:dev": "node ../love2d4me/scripts/build-web.js .",
    "serve": "npx --yes http-server Web -p 8080 -c-1"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "love.js": "^11.4.1"
  }
}
